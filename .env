# =========================
# PORTS (host -> container)
# =========================
LDAP_ADMIN_PORT=8080
PRIVACYIDEA_PORT=9000
KEYCLOAK_PORT=8082
OWNCLOUD_PORT=8081

# =========================
# LDAP 
# =========================

LDAP_BACKEND=mdb

LDAP_TLS=false
LDAP_TLS_CRT_FILENAME=ldap.crt
LDAP_TLS_KEY_FILENAME=ldap.key
LDAP_TLS_DH_PARAM_FILENAME=dhparam.pem
LDAP_TLS_CA_CRT_FILENAME=ca.crt
LDAP_TLS_ENFORCE=false
LDAP_TLS_VERIFY_CLIENT=demand

LDAP_KEEP_EXISTING_CONFIG=false
LDAP_REMOVE_CONFIG_AFTER_SETUP=true

PHPLDAPADMIN_HTTPS=false

# =========================
# privacyIDEA
# =========================
PI_DB_NAME=privacyidea
PI_DB_USER=privacyidea
PI_DB_PASSWORD=privacyidea

PI_SECRET_KEY=suppersecretkey
PI_PEPPER=secretworduseforadminencrypt
PI_PAGE_TITLE=privacyIDEA

PI_ADMIN_USER=admin
PI_ADMIN_PASSWORD=admin

# =========================
# Keycloak
# =========================
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak

KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# =========================
# ownCloud 
# =========================
OWNCLOUD_VERSION=10.16.1
OWNCLOUD_PORT=8081
OWNCLOUD_DOMAIN=localhost:8081
OWNCLOUD_TRUSTED_DOMAINS=localhost
OWNCLOUD_DB_NAME=owncloud
OWNCLOUD_DB_USERNAME=owncloud
OWNCLOUD_DB_PASSWORD=owncloud
OWNCLOUD_MYSQL_ROOT_PASSWORD=rootpass
OWNCLOUD_ADMIN_USERNAME=admin
OWNCLOUD_ADMIN_PASSWORD=admin